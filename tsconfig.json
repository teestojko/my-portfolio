{
    "compilerOptions": {
        "target": "ESNext",

        "module": "ESNext",

        "strict": true,

        "jsx": "react-jsx",

        "esModuleInterop": true,

        "moduleResolution": "bundler",

        "skipLibCheck": true,

        "forceConsistentCasingInFileNames": true,

        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },

    "include": [
        "src/**/*"
    ]
}

